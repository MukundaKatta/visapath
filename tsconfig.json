{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "paths": {
      "@visapath/regulations": ["./packages/regulations/index.ts"],
      "@visapath/ai-advisor": ["./packages/ai-advisor/index.ts"],
      "@visapath/supabase": ["./packages/supabase/index.ts"]
    }
  },
  "exclude": ["node_modules"]
}
